@page "/"
@using ChatApp.Services
@using ChatApp.Components
@using MudBlazor
@using ChatApp.Models
@inject ChatService ChatService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime
@inject ChatStateContainer ChatState

<div class="h-screen w-full bg-slate-50 flex items-center justify-center p-2 sm:p-4">
    <div class="w-full max-w-5xl h-full flex flex-col bg-white rounded-2xl shadow-xl overflow-hidden border border-slate-200">
        
        <div class="px-6 py-4 bg-white border-b border-slate-100 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="p-2 bg-indigo-50 rounded-lg">
                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Primary" />
                </div>
                <div>
                    <h1 class="text-slate-800 font-bold text-lg leading-none">GenAI Assistant</h1>
                    <span class="text-slate-400 text-xs flex items-center gap-1">
                        <span class="w-2 h-2 bg-green-500 rounded-full"></span> Online
                    </span>
                </div>
            </div>
        </div>

        <div class="flex-grow overflow-y-auto p-4 sm:p-6 bg-slate-50/50 space-y-6">
            @if (_messages == null || !_messages.Any())
            {
                <div class="h-full flex flex-col items-center justify-center text-slate-400">
                    <div class="w-20 h-20 mb-4 bg-slate-100 rounded-full flex items-center justify-center">
                        <MudIcon Icon="@Icons.Material.Filled.QuestionAnswer" Style="font-size: 2rem;" />
                    </div>
                    <p class="text-lg font-medium">Como posso ajudar hoje?</p>
                </div>
            }
            else
            {
                @foreach (var message in _messages)
                {
                    <div class="flex @(message.Role == "user" ? "justify-end" : "justify-start") animate-in fade-in slide-in-from-bottom-2 duration-300">
                        <div class="flex gap-3 max-w-[85%] sm:max-w-[70%] @(message.Role == "user" ? "flex-row-reverse" : "flex-row")">
                            
                            <div class="flex-shrink-0">
                                <MudAvatar Color="@(message.Role == "user" ? Color.Info : Color.Primary)"
                                           Variant="Variant.Filled"
                                           Class="shadow-sm">
                                    @(message.Role == "user" ? "U" : "AI")
                                </MudAvatar>
                            </div>

                            <div class="flex flex-col @(message.Role == "user" ? "items-end" : "items-start") w-full overflow-hidden">
                                <div class="px-4 py-3 rounded-2xl shadow-sm max-w-full overflow-x-auto @(message.Role == "user" ? "bg-indigo-600 text-white rounded-tr-none" : "bg-white text-slate-700 border border-slate-200 rounded-tl-none")">
                                    <MudMarkdown Value="@message.Content" />
                                </div>
                                
                                <div class="flex items-center gap-2 mt-1 px-1 @(message.Role == "user" ? "flex-row-reverse" : "flex-row")">
                                    <span class="text-[10px] text-slate-400">
                                        @message.Timestamp.ToString("HH:mm")
                                    </span>
                                    <button @onclick="() => CopyToClipboard(message.Content)"
                                            class="text-slate-400 hover:text-indigo-600 transition-colors flex items-center p-1 rounded hover:bg-slate-200/50"
                                            title="Copiar mensagem">
                                        <MudIcon Icon="@Icons.Material.Filled.ContentCopy" Style="font-size: 14px;" />
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                @if (_isLoading)
                {
                    <div class="flex justify-start">
                        <div class="bg-white border border-slate-200 px-4 py-3 rounded-2xl rounded-tl-none shadow-sm">
                            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
                        </div>
                    </div>
                }
            }
        </div>

        <div class="p-4 bg-white border-t border-slate-100">
            <div class="flex items-end gap-2 max-w-4xl mx-auto">
                <div class="flex-grow bg-slate-100 rounded-xl px-4 py-1 border border-transparent focus-within:border-indigo-400 focus-within:bg-white transition-all">
                    <MudTextField @bind-Value="@_messageInput"
                                  Placeholder="Pergunte qualquer coisa..."
                                  Underline="true"
                                  Margin="Margin.None"
                                  Lines="1"
                                  MaxLines="5"
                                  @onkeydown="@HandleKeyPress"
                                  Disabled="@_isLoading"
                                  Class="mt-0" />
                </div>

                <button @onclick="SendMessageAsync"
                        disabled="@(_isLoading || string.IsNullOrWhiteSpace(_messageInput))"
                        class="p-3 bg-indigo-600 hover:bg-indigo-700 disabled:bg-slate-300 text-white rounded-xl shadow-md transition-all active:scale-95">
                    <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Small" />
                </button>
            </div>
            <p class="text-[10px] text-center text-slate-400 mt-2">
                IA pode cometer erros. Verifique informações importantes.
            </p>
        </div>
    </div>
</div>

@code {
    private List<ChatMessage> _messages = new();
    private string _messageInput = string.Empty;
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        ChatService.OnMessagesChanged += RefreshUI;
        ChatState.OnChange += RefreshUI;
        await LoadMessages();
    }

    private async Task LoadMessages()
    {
        _messages = (await ChatService.GetMessagesAsync()).ToList();
        StateHasChanged();
    }

    private async void RefreshUI()
    {
        await InvokeAsync(async () => {
            await LoadMessages();
        });
    }

    private async Task SendMessageAsync()
    {
        if (string.IsNullOrWhiteSpace(_messageInput)) return;

        _isLoading = true;
        var userText = _messageInput;
        _messageInput = string.Empty;
        
        try
        {
            await ChatService.ProcessMessageAsync(userText);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessageAsync();
        }
    }

    private async Task CopyToClipboard(string text)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
            Snackbar.Add("Copiado!", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Erro ao copiar.", Severity.Error);
        }
    }

    public void Dispose()
    {
        ChatService.OnMessagesChanged -= RefreshUI;
        ChatState.OnChange -= RefreshUI;
    }
}
